DATABASE_URL=
UPLOAD_DIR=backend/uploads
MAX_UPLOAD_BYTES=104857600
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
# Preview deployments can use a regex, but production should prefer exact origins.
# ALLOWED_ORIGIN_REGEX=https://.*\\.vercel\\.app
ALLOWED_ORIGIN_REGEX=

LLM_PROVIDER=auto
LLM_REVIEW_ENABLED=0
LLM_REVIEW_BATCH_SIZE=1
LLM_REVIEW_CONCURRENCY=1
LLM_REVIEW_LIMIT=
LLM_REVIEW_TIMEOUT=90
LLM_REVIEW_SLEEP=0.2

# New/changed table profile drafting (stored once and reused by structure signature)
PROFILE_LLM_ENABLED=0
PROFILE_LLM_MODEL=gpt-5-mini

# 웹에서 연보를 업로드할 때 언어 LLM 검수까지 자동 실행합니다.
# 비용이 발생하므로 운영 환경에서 명시적으로 켜세요.
AUTO_IMPORT_INCLUDE_LLM=0

# BizRouter (selected automatically when this key exists)
BIZROUTER_API_KEY=
BIZROUTER_MODEL=openai/gpt-5-mini
BIZROUTER_BASE_URL=https://api.bizrouter.ai/v1

# Direct OpenAI fallback
OPENAI_API_KEY=
OPENAI_LLM_REVIEW_ENABLED=0
OPENAI_TRANSLATION_MODEL=gpt-5.4-mini
OPENAI_LLM_REVIEW_BATCH_SIZE=1
OPENAI_LLM_REVIEW_LIMIT=
OPENAI_LLM_REVIEW_TIMEOUT=90
OPENAI_LLM_REVIEW_SLEEP=0.2
